# Node
NODE_ENV=development
LOG_LEVEL=debug

# API
API_PORT=4000
API_URL=http://localhost:4000
JWT_SECRET=change-me-to-a-256-bit-secret-here-min-32-chars
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=30d

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASSWORD=localpass
DB_NAME=inventory
DB_URL=mysql://app:localpass@localhost:3306/inventory

# Atlas dev database (ephemeral container for generating migrations)
ATLAS_DEV_URL=docker://mysql/8/dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Web (Nuxt)
NUXT_PUBLIC_API_BASE=http://localhost:4000
NUXT_PUBLIC_APP_NAME="Inventory Platform"
WEB_ORIGIN=http://localhost:3000

# M-Pesa Daraja sandbox
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/v1/payments/mpesa/callback

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=inventory-api
